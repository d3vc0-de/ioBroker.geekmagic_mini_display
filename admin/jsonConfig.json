{
    "i18n": true,
    "type": "tabs",
    "items": {
        "tabMain": {
            "label": "General Settings",
            "type": "panel",
            "items": {
                "ipAddress": { "type": "text", "label": "IP Address", "sm": 6 },
                "updateInterval": { 
                    "type": "number", 
                    "label": "Update Interval (Seconds)", 
                    "default": 30, 
                    "min": 5, 
                    "max": 3600,
                    "sm": 6
                }
            }
        },
        "tabWidgets": {
            "label": "Display Widgets",
            "type": "panel",
            "items": {
                "widgets": {
                    "type": "table",
                    "label": "Widget Liste",
                    "items": [
                        { "type": "checkbox", "attr": "enabled", "title": "Aktiv", "width": "40px", "default": true },
                        { "type": "number", "attr": "slot", "title": "Slot", "width": "50px", "default": 0 },
                        { 
                            "type": "select", "attr": "pos", "title": "Pos", "width": "100px", 
                            "options": [
                                { "label": "Vollbild", "value": "full" },
                                { "label": "Oben Links", "value": "tl" },
                                { "label": "Oben Rechts", "value": "tr" },
                                { "label": "Unten Links", "value": "bl" },
                                { "label": "Unten Rechts", "value": "br" }
                            ],
                            "default": "full"
                        },
                        { "type": "objectId", "attr": "oid", "title": "Datenpunkt", "width": "200px" },
                        { 
                            "type": "select", "attr": "widgetType", "title": "Typ", "width": "90px", 
                            "options": [
                                { "label": "Text", "value": "text" },
                                { "label": "Tacho", "value": "gauge" },
                                { "label": "Balken", "value": "progress" },
                                { "label": "Kreis", "value": "circle" }
                            ],
                            "default": "text" 
                        },
                        { "type": "text", "attr": "label", "title": "Label", "width": "100px" },
                        { "type": "text", "attr": "unit", "title": "Unit", "width": "40px" },
                        { "type": "number", "attr": "decimals", "title": "Dezimal", "width": "50px", "default": 1 },
                        { "type": "color", "attr": "color", "title": "Farbe", "width": "50px", "default": "#00FF00" },
                        { "type": "number", "attr": "min", "title": "Min", "width": "60px", "default": 0, "step": 0.001 },
                        { "type": "number", "attr": "max", "title": "Max", "width": "60px", "default": 100, "step": 0.001 }
                    ]
                }
            }
        }
    }
}
